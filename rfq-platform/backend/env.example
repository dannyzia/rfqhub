# ==================================
# SERVER CONFIGURATION
# ==================================
NODE_ENV=development
PORT=3000

# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ==================================
# NEON POSTGRESQL DATABASE
# ==================================
# Get your connection string from: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://neondb_owner:your-password@your-host.neon.tech/neondb?sslmode=require

# Alternative: Individual database parameters (if not using DATABASE_URL)
# DB_HOST=your-host.neon.tech
# DB_PORT=5432
# DB_NAME=neondb
# DB_USER=neondb_owner
# DB_PASSWORD=your-password
# DB_SSL=true

# ==================================
# UPSTASH REDIS
# ==================================
# Get your connection string from: https://console.upstash.com
# Format: rediss://default:password@host:port
REDIS_URL=rediss://default:your-password@your-region.upstash.io:6379

# Alternative: Individual Redis parameters (if not using REDIS_URL)
# REDIS_HOST=your-region.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-password

# ==================================
# JWT AUTHENTICATION
# ==================================
# Generate secure secrets using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==================================
# EMAIL CONFIGURATION (SMTP)
# ==================================
# For Gmail: Use App Password (not regular password)
# https://support.google.com/accounts/answer/185833

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@rfqplatform.com

# ==================================
# FILE STORAGE (S3/MinIO)
# ==================================
# For local development: Use MinIO
# For production: Use AWS S3 or similar

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=rfq-documents
S3_REGION=us-east-1

# ==================================
# FRONTEND CONFIGURATION
# ==================================
FRONTEND_URL=http://localhost:5173

# ==================================
# RATE LIMITING
# ==================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==================================
# LOGGING
# ==================================
# Options: error, warn, info, debug, verbose
LOG_LEVEL=debug

# ==================================
# TENDER TYPE CONFIGURATION
# ==================================
# Caching TTL in seconds (24 hours = 86400)
TENDER_TYPE_CACHE_TTL=86400

# Document upload directory
UPLOAD_DIR=./uploads/tender-documents

# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# Enable analytics collection
ENABLE_TENDER_TYPE_ANALYTICS=true

# ==================================
# OPTIONAL: THIRD-PARTY SERVICES
# ==================================

# Stripe (for payments - if needed)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# SendGrid (alternative to SMTP)
# SENDGRID_API_KEY=SG...

# AWS S3 (for production file storage)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# AWS_BUCKET=rfq-prod-documents
